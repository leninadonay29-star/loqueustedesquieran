Algoritmo SumaResta
	Definir num1, num2, resta, suma Como Real 
	Escribir "Escriba el primer numero"
	Leer num1
	
	Escribir "Escriba el segundo numero"
	Leer num2
	suma <- num1 + num2
	resta <- num1 - num2
	Escribir " El resultado de la suma es ", suma
	Escribir " El resultado de la resta es ", resta
FinAlgoritmo
